{
  "openapi": "3.0.0",
  "info": {
    "title": "Quiz Maker API",
    "version": "1.0.0",
    "description": "Quiz creation and taking API for React take-home test"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local development server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use 'dev-token' for development"
      }
    },
    "schemas": {
      "Quiz": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "timeLimitSeconds": {
            "type": "integer",
            "nullable": true
          },
          "isPublished": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateQuizRequest": {
        "type": "object",
        "required": ["title", "description"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "timeLimitSeconds": {
            "type": "integer",
            "minimum": 60,
            "nullable": true
          },
          "isPublished": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "UpdateQuizRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "timeLimitSeconds": {
            "type": "integer",
            "minimum": 60,
            "nullable": true
          },
          "isPublished": {
            "type": "boolean"
          }
        }
      },
      "Question": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "quizId": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": ["mcq", "short", "code"]
          },
          "prompt": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "correctAnswer": {
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ],
            "nullable": true
          },
          "position": {
            "type": "integer"
          }
        }
      },
      "QuestionSanitized": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "quizId": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": ["mcq", "short", "code"]
          },
          "prompt": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "position": {
            "type": "integer"
          }
        }
      },
      "CreateQuestionRequest": {
        "type": "object",
        "required": ["type", "prompt"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["mcq", "short", "code"]
          },
          "prompt": {
            "type": "string",
            "minLength": 5
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "nullable": true
          },
          "correctAnswer": {
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ],
            "nullable": true
          },
          "position": {
            "type": "integer",
            "default": 0
          }
        }
      },
      "UpdateQuestionRequest": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "minLength": 5
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correctAnswer": {
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          },
          "position": {
            "type": "integer"
          }
        }
      },
      "QuizWithQuestions": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Quiz"
          },
          {
            "type": "object",
            "properties": {
              "questions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Question"
                }
              }
            }
          }
        ]
      },
      "Attempt": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "quizId": {
            "type": "integer"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "submittedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "answers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "questionId": {
                  "type": "integer"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "quiz": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "timeLimitSeconds": {
                "type": "integer",
                "nullable": true
              },
              "questions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/QuestionSanitized"
                }
              }
            }
          }
        }
      },
      "StartAttemptRequest": {
        "type": "object",
        "required": ["quizId"],
        "properties": {
          "quizId": {
            "type": "integer"
          }
        }
      },
      "AnswerQuestionRequest": {
        "type": "object",
        "required": ["questionId", "value"],
        "properties": {
          "questionId": {
            "type": "integer"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "AnswerResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "SubmitResult": {
        "type": "object",
        "properties": {
          "score": {
            "type": "integer"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "questionId": {
                  "type": "integer"
                },
                "correct": {
                  "type": "boolean"
                },
                "expected": {
                  "type": "string",
                  "nullable": true
                }
              }
            }
          }
        }
      },
      "RecordEventRequest": {
        "type": "object",
        "required": ["event"],
        "properties": {
          "event": {
            "type": "string"
          }
        }
      },
      "RecordEventResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid authorization token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Invalid request parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/quizzes": {
      "get": {
        "summary": "List all quizzes",
        "tags": ["quizzes"],
        "operationId": "getQuizzes",
        "responses": {
          "200": {
            "description": "List of quizzes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Quiz"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create a new quiz",
        "tags": ["quizzes"],
        "operationId": "createQuiz",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQuizRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Quiz created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quiz"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/quizzes/{id}": {
      "get": {
        "summary": "Get quiz with questions (creator view)",
        "tags": ["quizzes"],
        "operationId": "getQuizById",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Quiz with questions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuizWithQuestions"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "summary": "Update quiz metadata",
        "tags": ["quizzes"],
        "operationId": "updateQuiz",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateQuizRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quiz updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quiz"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/quizzes/{id}/questions": {
      "post": {
        "summary": "Add question to quiz",
        "tags": ["questions"],
        "operationId": "createQuestion",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQuestionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Question created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Question"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/questions/{id}": {
      "patch": {
        "summary": "Update question",
        "tags": ["questions"],
        "operationId": "updateQuestion",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateQuestionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Question updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Question"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "summary": "Delete question",
        "tags": ["questions"],
        "operationId": "deleteQuestion",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Question deleted"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/attempts": {
      "post": {
        "summary": "Start a quiz attempt",
        "tags": ["attempts"],
        "operationId": "startAttempt",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAttemptRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attempt started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Attempt"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/attempts/{id}/answer": {
      "post": {
        "summary": "Submit answer for a question",
        "tags": ["attempts"],
        "operationId": "answerQuestion",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnswerQuestionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Answer recorded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnswerResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/attempts/{id}/submit": {
      "post": {
        "summary": "Submit attempt for grading",
        "tags": ["attempts"],
        "operationId": "submitAttempt",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attempt graded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/attempts/{id}/events": {
      "post": {
        "summary": "Record anti-cheat event",
        "tags": ["attempts"],
        "operationId": "recordEvent",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordEventRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Event recorded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordEventResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  }
}
